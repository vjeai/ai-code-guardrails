{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "bash:npm run scan",
      "bash:npm run start",
      "bash:npm install",
      "bash:git status",
      "bash:git diff",
      "bash:git add",
      "bash:git commit",
      "bash:git push",
      "bash:semgrep"
    ],
    "deny": [
      "bash:rm -rf",
      "bash:curl",
      "bash:wget",
      "bash:chmod 777",
      "bash:sudo",
      "bash:eval",
      "bash:node -e"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; echo \"$f\" | grep -qE '\\.(js|ts)$' && semgrep --config /Users/tusshar/Documents/ai-code-guardrails/.semgrep/rules.yml \"$f\" --quiet; } 2>/dev/null || true",
            "statusMessage": "Scanning file for security issues..."
          }
        ]
      }
    ]
  }
}
