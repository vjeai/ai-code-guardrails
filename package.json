{
  "name": "ai-code-guardrails",
  "version": "1.0.0",
  "description": "Semantic Guardrail demo — Obsidian knowledge graph + CLAUDE.md + Semgrep enforcing security standards on AI-generated code",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "scan": "semgrep --config .semgrep/rules.yml src/",
    "scan:verbose": "semgrep --config .semgrep/rules.yml src/ --verbose",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage"
  },
  "jest": {
    "coverageProvider": "v8",
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/auth-vulnerable.js"
    ],
    "transform": {}
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
