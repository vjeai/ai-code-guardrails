{
  "name": "ai-code-guardrails",
  "version": "1.0.0",
  "description": "Semantic Guardrail demo — Obsidian knowledge graph + CLAUDE.md + Semgrep enforcing security standards on AI-generated code",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "scan": "semgrep --config .semgrep/rules.yml src/",
    "scan:verbose": "semgrep --config .semgrep/rules.yml src/ --verbose"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {}
}
